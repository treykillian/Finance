    },
    {
      "name": "Add Expense",
      "short_name": "Expense",
      "description": "Open Ledgerly to add an expense.",
      "url": "./index.html#transactions",
      "icons": [{ "src": "icons/icon-192.svg", "sizes": "192x192", "type": "image/svg+xml" }]
    },
    {
      "name": "Add Income",
      "short_name": "Income",
      "description": "Open Ledgerly to add income.",
      "url": "./index.html#transactions",
      "icons": [{ "src": "icons/icon-192.svg", "sizes": "192x192", "type": "image/svg+xml" }]
    },
    {
      "name": "View Budget",
      "short_name": "Budget",
      "description": "Open the monthly budget.",
      "url": "./index.html#budget",
      "icons": [{ "src": "icons/icon-192.svg", "sizes": "192x192", "type": "image/svg+xml" }]
    }
  ],
  "icons": [
    {
      "src": "icons/icon-192.svg",
