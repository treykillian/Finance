{
  "name": "Ledgerly v2 Money Dashboard",
  "short_name": "Ledgerly",
  "description": "A private, mobile-first personal finance PWA.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0f1013",
  "theme_color": "#0f1013",
